# API keys are stored in browser localStorage — no backend needed.
# Copy this to .env if you ever add a build/server layer.

# Finnhub API key (entered via dashboard Settings UI)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Twelve Data API key (entered via dashboard Settings UI)
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
